<Window x:Class="ServiceCenter.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        WindowStartupLocation="CenterScreen"
        Width="450" Height="550"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        WindowStyle="SingleBorderWindow" Icon="/Views/icons8-авторизация-50.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Height="60">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔧 Сервисный центр" FontSize="20" FontWeight="Bold" Foreground="#4A4A4A"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="20,10" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" 
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#5D9BEC"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Вход">
                <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                    <TextBlock Text="Авторизация" FontSize="18" FontWeight="Bold" Foreground="#4A4A4A" 
                               HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <TextBlock Text="Логин" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtLogin" Height="38" Padding="12,8" FontSize="14" 
                             Background="#F8F8F8" BorderThickness="0" Margin="0,0,0,15"/>

                    <TextBlock Text="Пароль" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassword" Height="38" Padding="12,8" FontSize="14" 
                                 Background="#F8F8F8" BorderThickness="0" Margin="0,0,0,20"/>

                    <Button x:Name="btnLogin" Content="Войти" Height="42" FontSize="14" FontWeight="SemiBold"
                            Background="#5D9BEC" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Click="BtnLogin_Click" Margin="0,0,0,15"/>

                    <TextBlock x:Name="txtError" Text="" Foreground="#E57373" FontSize="12" 
                               HorizontalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Регистрация">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Регистрация клиента" FontSize="18" FontWeight="Bold" 
                                   Foreground="#4A4A4A" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                        <TextBlock Text="ФИО" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtRegFullName" Height="38" Padding="12,8" FontSize="14" 
                                 Background="#F8F8F8" BorderThickness="0" Margin="0,0,0,15"/>

                        <TextBlock Text="Логин" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtRegLogin" Height="38" Padding="12,8" FontSize="14" 
                                 Background="#F8F8F8" BorderThickness="0" Margin="0,0,0,15"/>

                        <TextBlock Text="Пароль" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="txtRegPassword" Height="38" Padding="12,8" FontSize="14" 
                                     Background="#F8F8F8" BorderThickness="0" Margin="0,0,0,15"/>

                        <TextBlock Text="Подтверждение пароля" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="txtRegConfirmPassword" Height="38" Padding="12,8" FontSize="14" 
                                     Background="#F8F8F8" BorderThickness="0" Margin="0,0,0,15"/>

                        <TextBlock Text="Телефон" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtRegPhone" Height="38" Padding="12,8" FontSize="14" 
                                 Background="#F8F8F8" BorderThickness="0" Margin="0,0,0,15"/>

                        <TextBlock Text="Email" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtRegEmail" Height="38" Padding="12,8" FontSize="14" 
                                 Background="#F8F8F8" BorderThickness="0" Margin="0,0,0,20"/>

                        <Button x:Name="btnRegister" Content="Зарегистрироваться" Height="42" FontSize="14" FontWeight="SemiBold"
                                Background="#5D9BEC" Foreground="White" BorderThickness="0" Cursor="Hand"
                                Click="BtnRegister_Click" Margin="0,0,0,15"/>

                        <TextBlock x:Name="txtRegError" Text="" Foreground="#E57373" FontSize="12" 
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>