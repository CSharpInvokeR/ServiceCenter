<Window x:Class="ServiceCenter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ServiceCenter.Converters"
        Title="Сервисный центр"
        WindowStartupLocation="CenterScreen"
        Width="1300" Height="750"
        WindowState="Maximized"
        Background="#F5F5F5" Icon="/Views/icons8-сотрудники-50.ico">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#5D9BEC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button" x:Key="DangerButtonStyle">
            <Setter Property="Background" Value="#E57373"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔧 Сервисный центр" FontSize="18" FontWeight="Bold" Foreground="#4A4A4A" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" x:Name="txtUserInfo" FontSize="13" Foreground="#666666" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <Button Grid.Column="2" Content="✖ Выход" Width="80" Height="30" Background="#E0E0E0" BorderThickness="0" Cursor="Hand" Click="BtnExit_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="btnAdd" Content="➕ Новая заявка" Style="{StaticResource PrimaryButtonStyle}" Click="BtnAdd_Click"/>
                <Button x:Name="btnEdit" Content="✏️ Редактировать" Style="{StaticResource ActionButtonStyle}" Click="BtnEdit_Click" IsEnabled="False"/>
                <Button x:Name="btnDelete" Content="🗑️ Удалить" Style="{StaticResource DangerButtonStyle}" Click="BtnDelete_Click" IsEnabled="False"/>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="8" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtSearch" Grid.Column="0" Height="32" Padding="8,5" Background="#F8F8F8" BorderThickness="0" FontSize="13"/>

                    <ComboBox x:Name="cmbStatus" Grid.Column="1" Width="140" Height="32" Margin="8,0,0,0" 
                              SelectionChanged="CmbStatus_SelectionChanged" Background="#F8F8F8" BorderThickness="0">
                        <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                        <ComboBoxItem Content="В ожидании"/>
                        <ComboBoxItem Content="В работе"/>
                        <ComboBoxItem Content="Выполнено"/>
                    </ComboBox>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" Text="🔍 Поиск по номеру, оборудованию, описанию или клиенту" FontSize="11" Foreground="#999999" Margin="5,0,0,8"/>

            <DataGrid x:Name="dgRequests" Grid.Row="3" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="DgRequests_SelectionChanged"
                      Background="White"
                      BorderBrush="#E0E0E0"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      FontSize="12">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding NomerZayavki}" Width="80"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding DataSozdaniya, StringFormat=dd.MM.yyyy}" Width="85"/>
                    <DataGridTextColumn Header="Оборудование" Binding="{Binding NazvanieOborudovaniya}" Width="140"/>
                    <DataGridTextColumn Header="Неисправность" Binding="{Binding NazvanieTipa}" Width="130"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Opisanie}" Width="*" MinWidth="150"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="90"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ImyaKlienta}" Width="130"/>
                    <DataGridTextColumn Header="Исполнитель" Binding="{Binding ImyaIspolnitelya}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">

                    <StackPanel x:Name="statsPanel" Visibility="Collapsed">
                        <TextBlock Text="📊 Статистика" FontSize="16" FontWeight="Bold" Foreground="#4A4A4A" Margin="0,0,0,15"/>

                        <Border Background="#E8F0FE" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Всего заявок" FontSize="12" Foreground="#666666"/>
                                <TextBlock x:Name="txtTotal" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#E8F5E9" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Выполнено" FontSize="12" Foreground="#666666"/>
                                <TextBlock x:Name="txtCompleted" FontSize="28" FontWeight="Bold" Foreground="#27AE60"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFF3E0" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="В работе" FontSize="12" Foreground="#666666"/>
                                <TextBlock x:Name="txtInProgress" FontSize="28" FontWeight="Bold" Foreground="#F39C12"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#FCE4EC" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="В ожидании" FontSize="12" Foreground="#666666"/>
                                <TextBlock x:Name="txtWaiting" FontSize="28" FontWeight="Bold" Foreground="#E91E63"/>
                            </StackPanel>
                        </Border>

                        <Separator Margin="0,10,0,10" Background="#E0E0E0" Height="1"/>
                    </StackPanel>

                    <StackPanel x:Name="notificationPanel">
                        <TextBlock Text="📬 Уведомления" FontSize="16" FontWeight="Bold" Foreground="#4A4A4A" Margin="0,0,0,15"/>

                        <Border x:Name="notificationContent" Background="#E8F5E9" CornerRadius="8" Padding="12" BorderBrush="#27AE60" BorderThickness="1" Margin="0,0,0,10" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Content="✖" Width="25" Height="25" 
                    Background="Transparent" Foreground="#27AE60" BorderThickness="0"
                    FontWeight="Bold" FontSize="14" Cursor="Hand"
                    HorizontalAlignment="Right" Margin="0,0,0,5"
                    Click="BtnCloseNotification_Click"/>

                                <TextBlock Grid.Row="0" Text="✅ Заявка выполнена!" FontWeight="Bold" Foreground="#27AE60" Margin="0,0,25,5"/>

                                <TextBlock Grid.Row="1" x:Name="txtNotification" Text="" FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,5,0,10"/>

                                <TextBlock Grid.Row="2" Text="Отсканируйте QR-код для оценки:" FontSize="11" Foreground="#999999" Margin="0,0,0,5"/>

                                <Image Grid.Row="3" x:Name="qrImage" Height="120" Width="120" HorizontalAlignment="Center" Margin="0,5"/>

                                <TextBlock Grid.Row="4" x:Name="qrLink" Text="" FontSize="11" Foreground="Blue" TextDecorations="Underline" HorizontalAlignment="Center" MouseLeftButtonUp="QrLink_Click" Cursor="Hand" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>