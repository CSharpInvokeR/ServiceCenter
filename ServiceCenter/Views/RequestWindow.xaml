<Window x:Class="ServiceCenter.Views.RequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заявка"
        WindowStartupLocation="CenterOwner"
        Width="750" Height="650"
        ResizeMode="NoResize"
        Background="#F5F5F5" Icon="/Views/icons8-корзина-50.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="Button" x:Key="SaveButtonStyle">
            <Setter Property="Background" Value="#5D9BEC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button" x:Key="CancelButtonStyle">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button" x:Key="DeleteButtonStyle">
            <Setter Property="Background" Value="#E57373"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtTitle" FontSize="20" FontWeight="Bold" Foreground="#4A4A4A" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер:" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtNumber" Height="32" Padding="8" IsReadOnly="True" Background="#F8F8F8" BorderThickness="0"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDate" Height="32" Padding="8" IsReadOnly="True" Background="#F8F8F8" BorderThickness="0" Margin="0,10,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Оборудование:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cmbEquipment" Height="32" Padding="5" Margin="0,10,0,0" BorderThickness="0" Background="#F8F8F8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Неисправность:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cmbFaultType" Height="32" Padding="5" Margin="0,10,0,0" BorderThickness="0" Background="#F8F8F8"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Описание:" FontWeight="Bold" VerticalAlignment="Top" Margin="0,10,0,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtDescription" Height="80" Padding="8" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,10,0,0" BorderThickness="0" Background="#F8F8F8"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Клиент:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <ComboBox Grid.Row="5" Grid.Column="1" x:Name="cmbClient" Height="32" Padding="5" Margin="0,10,0,0" BorderThickness="0" Background="#F8F8F8"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Исполнитель:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <ComboBox Grid.Row="6" Grid.Column="1" x:Name="cmbEmployee" Height="32" Padding="5" Margin="0,10,0,0" BorderThickness="0" Background="#F8F8F8"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Статус:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cmbStatus" Height="32" Padding="5" Margin="0,10,0,0" BorderThickness="0" Background="#F8F8F8">
                            <ComboBoxItem Content="В ожидании"/>
                            <ComboBoxItem Content="В работе"/>
                            <ComboBoxItem Content="Выполнено"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💬 Комментарии" FontSize="14" FontWeight="Bold" Foreground="#4A4A4A" Margin="0,0,0,10"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                            <ItemsControl x:Name="lvComments" Margin="0,0,0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FAFAFA" CornerRadius="5" Padding="8" Margin="0,0,0,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ImyaPolzovatelya}" FontWeight="Bold" Foreground="#2C3E50"/>
                                                        <TextBlock Text=" - " Foreground="Gray"/>
                                                        <TextBlock Text="{Binding DataSozdaniya, StringFormat=dd.MM.yyyy HH:mm}" Foreground="Gray" FontSize="11"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding TekstDlyaOtobrazheniya}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="1" Content="✖" Width="25" Height="25" 
                                                        Background="#E57373" Foreground="White" BorderThickness="0"
                                                        FontWeight="Bold" Margin="5,0,0,0"
                                                        Tag="{Binding KomentariyId}"
                                                        Click="BtnDeleteComment_Click"
                                                        Visibility="{Binding MozhnoUdolit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtNewComment" Grid.Column="0" Height="32" Padding="8" Margin="0,0,5,0" Background="#F8F8F8" BorderThickness="0"/>
                            <Button x:Name="btnAddComment" Grid.Column="1" Content="Добавить" Width="90" Height="32" 
                                    Background="#5D9BEC" Foreground="White" BorderThickness="0" Click="BtnAddComment_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35" Margin="5" 
                    Background="#5D9BEC" Foreground="White" BorderThickness="0" Click="BtnSave_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Height="35" Margin="5" 
                    Background="#E57373" Foreground="White" BorderThickness="0" Click="BtnDelete_Click"/>
            <Button Content="Отмена" Width="100" Height="35" Margin="5" 
                    Background="#E0E0E0" Foreground="#4A4A4A" BorderThickness="0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>